{
  "name": "devloop-game",
  "version": "1.0.0",
  "description": "Solo coder developer idle game",
  "main": "main.js",
  "scripts": {
    "test": "jest",
    "sim": "node simulate.js"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "babel-jest": "^30.4.1",
    "htm": "^3.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "playwright": "^1.61.0",
    "preact": "^10.29.2"
  },
  "jest": {
    "testMatch": [
      "**/*.test.js"
    ],
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    },
    "moduleNameMapper": {
      "^preact/test-utils$": "<rootDir>/node_modules/preact/test-utils/dist/testUtils.js",
      "^preact$": "<rootDir>/node_modules/preact/dist/preact.js",
      "^preact/hooks$": "<rootDir>/node_modules/preact/hooks/dist/hooks.js",
      "^htm/preact$": "<rootDir>/node_modules/htm/preact/index.js",
      "^htm$": "<rootDir>/node_modules/htm/dist/htm.js"
    }
  }
}
